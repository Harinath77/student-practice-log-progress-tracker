# Leveluxe Modern Music Academy Backend Environment Variables

PROJECT_NAME="Leveluxe Modern Music Academy API"
ENV=development
PORT=8000

# CORS Configuration (comma-separated list of origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database Connection (Supabase PostgreSQL)
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://postgres:your-password@db.your-supabase-reference.supabase.co:5432/postgres
